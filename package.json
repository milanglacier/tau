{
  "name": "tau-mirror",
  "version": "1.0.8",
  "description": "Standalone web app for managing Pi RPC sessions in the browser",
  "keywords": [
    "pi",
    "coding-agent",
    "web-ui",
    "rpc",
    "standalone"
  ],
  "author": "deflating",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/deflating/tau.git"
  },
  "bin": {
    "tau": "./bin/tau.js"
  },
  "files": [
    "bin",
    "public",
    "extensions",
    "src",
    "tsconfig.json",
    "tsconfig.server.json",
    "tsconfig.public.json",
    "tsconfig.extensions.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.server.json && tsc -p tsconfig.public.json && tsc -p tsconfig.extensions.json",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.public.json --noEmit && tsc -p tsconfig.extensions.json --noEmit",
    "test": "npm run build && node --test"
  },
  "dependencies": {
    "qrcode": "^1.5.0",
    "ws": "^8.16.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.9",
    "@types/node": "^26.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3"
  }
}
